);

if(senha !== "11122025"){
    document.body.innerHTML = `
    <div style="text-align:center;margin-top:100px;font-family:Arial;">
        <h1>💔 Senha incorreta</h1>
        <p>Tente lembrar da data mais especial para nós. ❤️</p>
    </div>
    `;
    throw new Error("Acesso negado");
}
</script>
